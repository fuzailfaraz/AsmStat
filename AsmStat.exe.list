[ 325]    078A: 33 D2                                 xor dx, dx          ; Clear DX for division
[ 326]    078C: 8B 1E D3 04                           mov bx, arr_len
[ 327]    0790: F7 F3                                 div bx              ; DX:AX / BX = AX (Quotient)
[ 328]    0792: C3                                    ret
[ 329]        :                                       asm_mean endp
[ 330]        :                                       
[ 331]        :                                       ;-----------------------------------------
[ 332]        :                                       ; PROCEDURE: Calculate Variance (Integer)
[ 333]        :                                       ; Var = Sum((x - mean)^2) / N
[ 334]        :                                       ; Returns: AX = Variance
[ 335]        :                                       ;-----------------------------------------
[ 336]    0793:                                       asm_variance proc
[ 337]    0793: E8 F1 FF                              call asm_mean       ; Calculate mean
[ 338]    0796: 8B D8                                 mov bx, ax          ; BX = mean
[ 339]        :                                       
[ 340]    0798: BE AB 04                              lea si, array
[ 341]    079B: 8B 0E D3 04                           mov cx, arr_len
[ 342]    079F: 33 FF                                 xor di, di          ; DI will hold sum of squares
[ 343]        :                                       
[ 344]    07A1:                                       var_loop:
[ 345]    07A1: 8B 04                                 mov ax, [si]        ; AX = current element
[ 346]    07A3: 2B C3                                 sub ax, bx          ; AX = element - mean (can be negative)
[ 347]    07A5: F7 E8                                 imul ax             ; AX = AX * AX (squares remove negatives)
[ 348]    07A7: 03 F8                                 add di, ax          ; Accumulate square into DI
[ 349]    07A9: 83 C6 02                              add si, 2
[ 350]    07AC: E2 F3                                 loop var_loop
[ 351]        :                                       
[ 352]    07AE: 8B C7                                 mov ax, di          ; Move sum of squares to AX
[ 353]    07B0: 33 D2                                 xor dx, dx          ; Clear DX
[ 354]    07B2: 8B 1E D3 04                           mov bx, arr_len
[ 355]    07B6: F7 F3                                 div bx              ; Divide by N to get variance
[ 356]    07B8: C3                                    ret
[ 357]        :                                       asm_variance endp
[ 358]        :                                       
[ 359]        :                                       ;-----------------------------------------
[ 360]        :                                       ; PROCEDURE: Bubble Sort (O(N^2))
[ 361]        :                                       ; Modifies array in memory
[ 362]        :                                       ;-----------------------------------------
[ 363]    07B9:                                       bubble_sort proc
[ 364]    07B9: 8B 0E D3 04                           mov cx, arr_len
[ 365]    07BD: 49                                    dec cx              ; CX = N - 1 (Number of passes)
[ 366]    07BE: 74 1A                                 jz sort_done        ; If N=1, it's already sorted
[ 367]        :                                       
[ 368]    07C0:                                       outer_loop:
[ 369]    07C0: 51                                    push cx             ; Save outer loop counter
[ 370]    07C1: BE AB 04                              lea si, array       ; Reset pointer to start of array
[ 371]    07C4:                                       inner_loop:
[ 372]    07C4: 8B 04                                 mov ax, [si]        ; Load current element
[ 373]    07C6: 8B 5C 02                              mov bx, [si+2]      ; Load next element
[ 374]    07C9: 3B C3                                 cmp ax, bx          ; Compare them
[ 375]    07CB: 7E 05                                 jle no_swap         ; If current <= next, do nothing
[ 376]        :                                       
[ 377]        :                                       ; Perform Swap
[ 378]    07CD: 89 1C                                 mov [si], bx        ; Put smaller number in current slot
[ 379]    07CF: 89 44 02                              mov [si+2], ax      ; Put larger number in next slot
[ 380]        :                                       
[ 381]    07D2:                                       no_swap:
[ 382]    07D2: 83 C6 02                              add si, 2           ; Move to next adjacent pair
[ 383]    07D5: E2 ED                                 loop inner_loop     ; End of inner loop
[ 384]        :                                       
[ 385]    07D7: 59                                    pop cx              ; Restore outer loop counter
[ 386]    07D8: E2 E6                                 loop outer_loop     ; End of outer loop
[ 387]    07DA:                                       sort_done:
[ 388]    07DA: C3                                    ret
[ 389]        :                                       bubble_sort endp
[ 390]        :                                       
[ 391]        :                                       ;-----------------------------------------
[ 392]        :                                       ; PROCEDURE: Median (Assumes array is sorted)
[ 393]        :                                       ; Returns: AX = Median
[ 394]        :                                       ;-----------------------------------------
[ 395]    07DB:                                       asm_median proc
[ 396]    07DB: A1 D3 04                              mov ax, arr_len
[ 397]    07DE: D1 E8                                 shr ax, 1           ; AX = N / 2
[ 398]    07E0: 8B D8                                 mov bx, ax
[ 399]    07E2: D1 E3                                 shl bx, 1           ; Multiply by 2 for byte offset
[ 400]    07E4: BE AB 04                              lea si, array
[ 401]    07E7: 03 F3                                 add si, bx          ; SI now points to middle of array
[ 402]        :                                       
[ 403]    07E9: A1 D3 04                              mov ax, arr_len
[ 404]    07EC: A9 01 00                              test ax, 1          ; Check if N is odd or even
[ 405]    07EF: 75 0A                                 jnz is_odd
[ 406]        :                                       
[ 407]    07F1:                                       is_even:
[ 408]        :                                       ; For even arrays, median is average of two middle elements
[ 409]    07F1: 8B 04                                 mov ax, [si]        ; Middle right
[ 410]    07F3: 8B 5C FE                              mov bx, [si-2]      ; Middle left
[ 411]    07F6: 03 C3                                 add ax, bx
[ 412]    07F8: D1 E8                                 shr ax, 1           ; Divide by 2
[ 413]    07FA: C3                                    ret
[ 414]        :                                       
[ 415]    07FB:                                       is_odd:
[ 416]        :                                       ; For odd arrays, median is just the exact middle element
[ 417]    07FB: 8B 04                                 mov ax, [si]
[ 418]    07FD: C3                                    ret
[ 419]        :                                       asm_median endp
[ 420]        :                                       
[ 421]        :                                       ;-----------------------------------------
[ 422]        :                                       ; PROCEDURE: Find Minimum
[ 423]        :                                       ; Returns: AX = Min
[ 424]        :                                       ;-----------------------------------------
[ 425]    07FE:                                       asm_min proc
[ 426]    07FE: BE AB 04                              lea si, array
[ 427]    0801: 8B 0E D3 04                           mov cx, arr_len
[ 428]    0805: 8B 04                                 mov ax, [si]        ; Assume first element is min
[ 429]    0807: 83 C6 02                              add si, 2
[ 430]    080A: 49                                    dec cx
[ 431]    080B: 74 0B                                 jz min_done
[ 432]    080D:                                       min_loop:
[ 433]    080D: 3B 04                                 cmp ax, [si]
[ 434]    080F: 7E 02                                 jle min_skip
[ 435]    0811: 8B 04                                 mov ax, [si]        ; Update min
[ 436]    0813:                                       min_skip:
[ 437]    0813: 83 C6 02                              add si, 2
[ 438]    0816: E2 F5                                 loop min_loop
[ 439]    0818:                                       min_done:
[ 440]    0818: C3                                    ret
[ 441]        :                                       asm_min endp
[ 442]        :                                       
[ 443]        :                                       ;-----------------------------------------
[ 444]        :                                       ; PROCEDURE: Find Maximum
[ 445]        :                                       ; Returns: AX = Max
[ 446]        :                                       ;-----------------------------------------
[ 447]    0819:                                       asm_max proc
[ 448]    0819: BE AB 04                              lea si, array
[ 449]    081C: 8B 0E D3 04                           mov cx, arr_len
[ 450]    0820: 8B 04                                 mov ax, [si]        ; Assume first element is max
[ 451]    0822: 83 C6 02                              add si, 2
[ 452]    0825: 49                                    dec cx
[ 453]    0826: 74 0B                                 jz max_done
[ 454]    0828:                                       max_loop:
[ 455]    0828: 3B 04                                 cmp ax, [si]
[ 456]    082A: 7D 02                                 jge max_skip
[ 457]    082C: 8B 04                                 mov ax, [si]        ; Update max
[ 458]    082E:                                       max_skip:
[ 459]    082E: 83 C6 02                              add si, 2
[ 460]    0831: E2 F5                                 loop max_loop
[ 461]    0833:                                       max_done:
[ 462]    0833: C3                                    ret
[ 463]        :                                       asm_max endp
